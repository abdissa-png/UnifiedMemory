# Core infrastructure
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
NEO4J_URI=bolt://localhost:7687
NEO4J_AUTH_USER=neo4j
NEO4J_AUTH_PASSWORD=password
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=unified_memory_content

# Optional API keys for external services
QDRANT_API_KEY=
ELASTICSEARCH_API_KEY=

# OpenAI / compatible LLMs
OPENAI_API_KEY=
OPENAI_BASE_URL=

# BGE Reranker (for rerankers)
BGE_RERANKER_MODEL=BAAI/bge-reranker-base

# Cohere (for rerankers)
COHERE_API_KEY=
COHERE_RERANKER_MODEL=rerank-english-v3.0
# General application settings
LOG_LEVEL=INFO

# UMS specific settings
UMS_CONFIG=config/app.example.yaml
UMS_JWT_SECRET=change-me-in-production
UMS_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/unified_memory_test
UMS_ENABLE_INNGEST=1