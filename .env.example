# Core infrastructure
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
NEO4J_URI=bolt://neo4j:7687
NEO4J_AUTH_USER=neo4j
NEO4J_AUTH_PASSWORD=password
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX=unified_memory_content

# Optional API keys for external services
QDRANT_API_KEY=
ELASTICSEARCH_API_KEY=

# OpenAI / compatible LLMs
OPENAI_API_KEY=
OPENAI_BASE_URL=

# BGE Reranker (for rerankers)
BGE_RERANKER_MODEL=BAAI/bge-reranker-base

# Cohere (for rerankers)
COHERE_API_KEY=
COHERE_RERANKER_MODEL=rerank-english-v3.0
# General application settings
LOG_LEVEL=INFO

# UMS specific settings
UMS_CONFIG=config/app.example.yaml
UMS_JWT_SECRET=change-me-in-production
UMS_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/unified_memory_test
UMS_ENABLE_INNGEST=1
# Skip Alembic in API lifespan if migrations run elsewhere (e.g. Docker entrypoint).
UMS_SKIP_DB_INIT=0
# Dev-only: if Alembic fails, allow SQLAlchemy create_all (not for production).
UMS_SQL_CREATE_ALL_FALLBACK=0
# API log level (see unified_memory.api.app _configure_application_logging)
UMS_LOG_LEVEL=INFO

# Inngest settings
INNGEST_IS_PRODUCTION=0
INNGEST_EVENT_API_BASE_URL=http://inngest-dev:8288
INNGEST_API_BASE_URL=http://inngest-dev:8288
INNGEST_EVENT_KEY=